{
	"name": "portfolio",
	"version": "1.0.0",
	"private": true,
	"description": "My portfolio with Astro using TypeScript.",
	"homepage": "https://roottool.vercel.app",
	"bugs": {
		"url": "https://github.com/roottool/portfolio/issues"
	},
	"license": "MIT",
	"author": {
		"name": "roottool",
		"url": "https://github.com/roottool"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/roottool/portfolio.git"
	},
	"scripts": {
		"dev": "astro dev",
		"build": "bun run scripts/generate-og.ts && astro build",
		"preview": "astro preview",
		"astro": "astro",
		"lint": "run-s -c lint:*",
		"lint:dprint": "dprint check",
		"lint:oxfmt": "oxfmt --check",
		"lint:oxeslint": "astro check && oxlint && eslint --max-warnings=0 .",
		"lint:markuplint": "markuplint \"**/*.astro\"",
		"fix": "run-s -c fix:* format",
		"fix:oxeslint": "oxlint --fix && eslint --fix .",
		"format": "run-s -c format:*",
		"format:oxfmt": "oxfmt",
		"format:dprint": "dprint fmt"
	},
	"dependencies": {
		"@astrojs/check": "0.9.9",
		"@fontsource/cinzel-decorative": "5.2.8",
		"@fontsource/cormorant-garamond": "5.2.11",
		"@fontsource/cormorant-sc": "5.2.8",
		"astro": "6.4.6"
	},
	"devDependencies": {
		"@markuplint/astro-parser": "4.18.3",
		"@resvg/resvg-js": "2.6.2",
		"@tailwindcss/vite": "4.3.0",
		"@types/node": "25.9.1",
		"dprint": "0.54.0",
		"eslint": "10.4.1",
		"eslint-config-flat-gitignore": "2.3.0",
		"eslint-plugin-astro": "1.7.0",
		"eslint-plugin-oxlint": "1.68.0",
		"globals": "17.6.0",
		"markuplint": "4.18.3",
		"npm-run-all2": "9.0.1",
		"oxfmt": "0.54.0",
		"oxlint": "1.68.0",
		"oxlint-tsgolint": "0.23.0",
		"satori": "0.26.0",
		"tailwindcss": "4.3.0",
		"typescript": "6.0.3"
	},
	"msw": {
		"workerDirectory": "public"
	}
}
