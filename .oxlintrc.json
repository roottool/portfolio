{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": ["eslint", "unicorn", "typescript", "oxc", "jsx-a11y", "import", "promise"],
	"categories": {
		"correctness": "error",
		"suspicious": "warn"
	},
	"options": {
		"typeAware": true,
		// "typeCheck": true,
		"maxWarnings": 0
	},
	"env": {
		"builtin": true,
		"browser": true
	},
	"ignorePatterns": ["public"],
	"rules": {
		"no-unused-vars": [
			"error",
			{
				"fix": {
					"imports": "safe-fix",
					"variables": "off"
				}
			}
		],
		"import/no-unassigned-import": ["warn", { "allow": ["**/*.css"] }]
	},
	"overrides": [
		{
			"files": ["scripts/**/*.ts"],
			"rules": {
				"no-underscore-dangle": ["warn", { "allow": ["__dirname", "__filename"] }]
			}
		}
	]
}
