---

---

<section class="flex flex-col gap-4">
	<h2 class="vk-section-title" lang="en">
		<span style="color: var(--vk-gold); font-size: 1rem;">♪</span>
		Spotify Top Songs 2025
	</h2>

	<div
		style="
			border-radius: 2px;
			overflow: hidden;
			border: 1px solid var(--vk-border);
			box-shadow: var(--vk-glow);
			position: relative;
		"
	>
		<!-- Gold corner ornaments -->
		<span
			aria-hidden="true"
			style="
				position: absolute; top: -1px; left: -1px;
				width: 10px; height: 10px;
				border-top: 1px solid var(--vk-silver-dim);
				border-left: 1px solid var(--vk-silver-dim);
				z-index: 1;
			"
		></span>
		<span
			aria-hidden="true"
			style="
				position: absolute; bottom: -1px; right: -1px;
				width: 10px; height: 10px;
				border-bottom: 1px solid var(--vk-silver-dim);
				border-right: 1px solid var(--vk-silver-dim);
				z-index: 1;
			"
		></span>

		<iframe
			data-testid="embed-iframe"
			style="border-radius: 0; display: block;"
			src="https://open.spotify.com/embed/playlist/37i9dQZEVXd8D7v4N65TZe?utm_source=generator&theme=0"
			width="100%"
			height="352"
			allowfullscreen=""
			allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
			loading="lazy"
			class="border-0"
		></iframe>
	</div>
</section>
